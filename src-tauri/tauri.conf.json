{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../ui",
    "distDir": "../ui",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "gnbpcap",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "open": true
      },
      "shell": {
        "all": false
      }
    },
    "bundle": {
      "active": false,
      "icon": [],
      "identifier": "com.gnbpcap.viewer"
    },
    "windows": [
      {
        "title": "5G NR Ladder Diagram",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ]
  }
}
